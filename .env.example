SPILLI_BRIDGE_HOST=127.0.0.1
SPILLI_BRIDGE_PORT=8888
# Docker Compose PEM directory mount source. Defaults to ${HOME}/.spilli in docker-compose.yml.
# SPILLI_PEM_DIR=/path/to/.spilli
# Same default PEM directory used by the VS Code extension.
SPILLI_KEY_PATH=~/.spilli
# Model inventory scope: public, private, team, team.<name>, or enterprise.
# "community" is accepted as an alias for public.
SPILLI_BRIDGE_SCOPE=private
# SPILLI_BRIDGE_TEAM=
# Optional. When set, requests must send Authorization: Bearer <token>,
# X-Api-Key: <token>, or api-key: <token>.
# SPILLI_BRIDGE_AUTH_TOKEN=sk-spilli-local
# SPILLI_BRIDGE_REQUEST_TIMEOUT_MS=600000
# SPILLI_BRIDGE_MODEL_CACHE_TTL_MS=30000
# Reuse acquired SpiLLI resource sessions by model/scope. Set to 0 to force a
# fresh resource request for every inference request while debugging.
# SPILLI_BRIDGE_REUSE_SESSIONS=1
# SPILLI_BRIDGE_NATIVE_CACHE_DIR=./.native-cache
