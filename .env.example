SPILLI_BRIDGE_HOST=127.0.0.1
SPILLI_BRIDGE_PORT=8888
# Docker Compose PEM directory mount source. Defaults to ${HOME}/.spilli in docker-compose.yml.
# SPILLI_PEM_DIR=/path/to/.spilli
# Same default PEM directory used by the VS Code extension.
SPILLI_KEY_PATH=~/.spilli
# SPILLI_BRIDGE_TEAM=
# Optional. When set, requests must send Authorization: Bearer <token>,
# X-Api-Key: <token>, or api-key: <token>.
# SPILLI_BRIDGE_AUTH_TOKEN=sk-spilli-local
# Allocation timeout for acquiring a SpiLLI model/session.
# SPILLI_BRIDGE_ALLOCATION_TIMEOUT_MS=60000
# Inference timeout for long prompt hydration/generation runs.
# SPILLI_BRIDGE_RUN_TIMEOUT_MS=300000
# SPILLI_BRIDGE_MODEL_CACHE_TTL_MS=30000
# Maximum characters from any single Claude/Anthropic tool result forwarded
# into the local model context. Prevents large file/search outputs from
# drowning the post-tool continuation prompt.
# SPILLI_BRIDGE_MAX_TOOL_RESULT_CHARS=8000
# Optional diagnostic override for aggregate message-history characters during
# hydration. Leave unset so SpiLLIHost's advertised safe context token budget is
# authoritative.
# SPILLI_BRIDGE_MAX_HISTORY_CHARS=
# Conservative text-to-token conversion used with host-reported context limits.
# SPILLI_BRIDGE_CONTEXT_CHARS_PER_TOKEN=3
# Fraction of the host context left for input history after prompt/output reserve.
# SPILLI_BRIDGE_CONTEXT_INPUT_BUDGET_FRACTION=0.72
# Minimum output-token reserve when deriving bridge history budget from host limits.
# SPILLI_BRIDGE_CONTEXT_OUTPUT_RESERVE_TOKENS=1024
# Release Claude Code subagent KV leases after each completed/failed request.
# SPILLI_BRIDGE_RELEASE_EPHEMERAL_CONTEXTS=1
# Maximum warm durable main-session contexts retained per SpiLLI resource.
# SPILLI_BRIDGE_MAX_DURABLE_CONTEXTS_PER_RESOURCE=2
# Response mode: raw returns SpiLLI model text as assistant text; compat parses
# Harmony/JSON tool calls into Anthropic/OpenAI tool-call objects.
# SPILLI_BRIDGE_RESPONSE_MODE=compat
# In compat mode, if SpiLLIHost reports max_tokens and Claude Code advertised
# AskUserQuestion, synthesize a continuation question through that tool.
# SPILLI_BRIDGE_ASK_CONTINUE_ON_MAX_TOKENS=1
# SPILLI_BRIDGE_NATIVE_CACHE_DIR=./.native-cache
# Optional server-side web search emulation for Claude Code WebSearch.
# If unset, DuckDuckGo is used as a free best-effort fallback.
# Use {query} for GET endpoints, otherwise the bridge POSTs
# {"query":"...","max_results":5} and accepts common results/items shapes.
# SPILLI_BRIDGE_WEB_SEARCH_ENDPOINT=http://127.0.0.1:8765/search?q={query}
# SPILLI_BRIDGE_WEB_SEARCH_TIMEOUT_MS=10000
# SPILLI_BRIDGE_WEB_SEARCH_MAX_RESULTS=5
# Tool-result context policy for Claude/Codex agent loops.
# Small results are forwarded raw. Medium results are deterministically
# compacted. Very large results are marked as summarizer-recommended and
# compacted to a smaller pre-summary until an external summarizer is wired in.
# SPILLI_BRIDGE_TOOL_RESULT_RAW_CHARS=4000
# SPILLI_BRIDGE_TOOL_RESULT_COMPACT_CHARS=16000
# SPILLI_BRIDGE_TOOL_RESULT_COMPACT_TARGET_CHARS=6000
# SPILLI_BRIDGE_TOOL_RESULT_SUMMARY_TARGET_CHARS=3000
# SPILLI_BRIDGE_TOOL_RESULT_SUMMARIZER_ENABLED=1
# SPILLI_BRIDGE_TOOL_RESULT_SUMMARIZER_MODEL=Openai_Gpt_Oss_20b
# SPILLI_BRIDGE_TOOL_RESULT_SUMMARIZER_TIMEOUT_MS=60000
# SPILLI_BRIDGE_TOOL_RESULT_SUMMARIZER_ENDPOINT=http://127.0.0.1:8766/summarize
# Legacy alias for SPILLI_BRIDGE_TOOL_RESULT_COMPACT_CHARS.
# SPILLI_BRIDGE_MAX_TOOL_RESULT_CHARS=8000
# Optional local debugging: log request/header shape without prompts or model
# responses. Useful for tracing Claude Code request metadata.
# SPILLI_BRIDGE_TRACE_REQUEST_SHAPES=0
# SPILLI_BRIDGE_REQUEST_LOG_PATH=~/.spilli/spilli-api-bridge-requests.jsonl
